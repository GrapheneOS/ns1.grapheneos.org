"      ips = {ips_sea, ips_lax, ips_dal, ips_yto, ips_mia, ips_lon, ips_ams, ips_nue, ips_sao, ips_tyo, ips_sin, ips_syd}"
"    elseif (cc == 'us' and not re_us_mia[re]) or cc_na_yto[cc] then"
"      ips = {ips_yto, ips_mia, ips_dal, ips_sea, ips_lax, ips_lon, ips_ams, ips_nue, ips_sao, ips_tyo, ips_sin, ips_syd}"
