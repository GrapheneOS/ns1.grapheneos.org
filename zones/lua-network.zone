"    if cc_as_nue[cc] then"
"      ips = {ips_nue, ips_ams, ips_lon, ips_yto, ips_mia, ips_dal, ips_lax, ips_sea, ips_sin, ips_tyo, ips_sao, ips_syd}"
"    elseif cc_as_tyo[cc] then"
"      ips = {ips_tyo, ips_sin, ips_lax, ips_sea, ips_dal, ips_yto, ips_mia, ips_nue, ips_ams, ips_lon, ips_syd, ips_sao}"
